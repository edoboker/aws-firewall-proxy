# Copy this file to terraform.tfvars and adjust values before running terraform apply.

aws_region        = "eu-north-1"
availability_zone = "eu-north-1a"
environment       = "dev"

vpc_cidr                    = "10.0.0.0/16"
workload_subnet_cidr        = "10.0.1.0/24"
direct_workload_subnet_cidr = "10.0.5.0/24"
proxy_subnet_cidr           = "10.0.2.0/24"
firewall_subnet_cidr        = "10.0.3.0/24"
public_subnet_cidr          = "10.0.4.0/24"

proxy_instance_type    = "t3.small"
workload_instance_type = "t3.micro"

# FQDNs allowed through AWS Network Firewall (all others blocked)
allowed_fqdns = [
  "google.com",
  "amazonaws.com",
  "cdn.amazonlinux.com"
]

# Hosts allowed by the experimental cleartext HTTP Host/original-dst guard.
# Terraform publishes these into the AppConfig runtime policy used by port 80.
http_allowed_hosts = [
  "google.com",
  "amazonaws.com",
  "cdn.amazonlinux.com"
]

# AppConfig-backed DNS/enforcement policy for the experimental HTTP guard.
http_dns_queries_per_host = 3
http_enforcement_mode     = "strict"

# Experimental ruleset generator. When enabled, the main stack creates the
# resolver Lambda, managed prefix list, separate IP-set-backed stateful rule
# group, and attaches that rule group to the firewall policy.
enable_ruleset_generator          = false
enable_ruleset_generator_schedule = false
ruleset_generator_fqdns = [
  "login.microsoftonline.com",
  "wiz.io",
  "amazon.com",
  "ynet.co.il",
  "github.com",
  "gitlab.com"
]

# Public recursive DNS resolvers the demo Network Firewall policy lets the
# proxy query directly. Route 53 Resolver (169.254.169.253) is automatically
# added to the AppConfig runtime policy and stays inside the VPC resolver path.
proxy_public_dns_resolvers = [
  "1.1.1.1",
  "8.8.8.8"
]
