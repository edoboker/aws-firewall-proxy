{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["allowed_hosts", "dns", "enforcement"],
  "properties": {
    "allowed_hosts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dns": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolvers", "queries_per_host"],
      "properties": {
        "resolvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "queries_per_host": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        }
      }
    },
    "enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["strict", "audit"]
        }
      }
    }
  }
}
