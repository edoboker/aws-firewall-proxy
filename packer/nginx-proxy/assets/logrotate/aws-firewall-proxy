/var/log/nginx/*.log {
    daily
    rotate 7
    missingok
    notifempty
    compress
    delaycompress
    create 0640 nginx nginx
    sharedscripts
    postrotate
        if [ -s /var/run/nginx.pid ]; then
            kill -USR1 "$(cat /var/run/nginx.pid)" 2>/dev/null || true
        fi
    endscript
}

/var/log/aws-firewall-proxy/runtime-sync.log {
    daily
    rotate 7
    missingok
    notifempty
    compress
    delaycompress
    create 0640 root root
}
